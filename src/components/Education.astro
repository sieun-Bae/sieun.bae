---
import data from '../data/education.json'
---

<section id="education" class="py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">Background & achievements</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">Education & More</h2>

    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Education</p>
        {data.education.map(edu => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
            <h3 class="font-semibold text-gray-900">{edu.school}</h3>
            <p class="text-sm font-medium text-blue-600 mt-1">{edu.degree}</p>
            <p class="text-xs text-gray-400 mt-0.5">{edu.note}</p>
            <p class="text-xs text-gray-400 mt-2">{edu.period}</p>
            <p class="text-sm text-gray-600 mt-2">GPA: {edu.gpa}</p>
          </div>
        ))}

        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Leadership</p>
        <div class="space-y-5">
          {data.leadership.map(item => (
            <div class="pl-4 border-l-2 border-gray-200">
              <p class="font-medium text-gray-800 text-sm">{item.title}</p>
              <p class="text-xs text-gray-400 mb-1">{item.location} · {item.period}</p>
              <p class="text-sm text-gray-500">{item.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Certifications</p>
        <div class="space-y-1">
          {data.certifications.map(cert => (
            <div class="flex items-start gap-3 py-3 border-b border-gray-100 last:border-0">
              <span class="text-xs font-mono text-blue-500 shrink-0 mt-0.5 w-10">{cert.year}</span>
              <div>
                <p class="text-sm font-medium text-gray-800">{cert.name}</p>
                <p class="text-xs text-gray-400">{cert.issuer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
