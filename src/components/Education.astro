---
import { useTranslations, type Lang } from '../i18n/translations'
import data from '../data/education.json'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)
const s = t.sections.education
const ed = t.education
---

<section id="education" class="py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">{s.eyebrow}</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">{s.heading}</h2>

    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">{ed.educationLabel}</p>
        {data.education.map(edu => {
          const local = edu[lang]
          return (
            <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
              <h3 class="font-semibold text-gray-900">{edu.school}</h3>
              <p class="text-sm font-medium text-blue-600 mt-1">{local.degree}</p>
              <p class="text-xs text-gray-400 mt-0.5">{local.note}</p>
              <p class="text-xs text-gray-400 mt-2">{edu.period}</p>
              <p class="text-sm text-gray-600 mt-2">GPA: {edu.gpa}</p>
            </div>
          )
        })}

        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">{ed.leadershipLabel}</p>
        <div class="space-y-5">
          {data.leadership.map(item => (
            <div class="pl-4 border-l-2 border-gray-200">
              <p class="font-medium text-gray-800 text-sm">{item.title}</p>
              <p class="text-xs text-gray-400 mb-1">{item.location} · {item.period}</p>
              <p class="text-sm text-gray-500">{item[lang].description}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">{ed.certificationsLabel}</p>
        <div class="space-y-1 mb-10">
          {data.certifications.map(cert => (
            <div class="flex items-start gap-3 py-3 border-b border-gray-100 last:border-0">
              <span class="text-xs font-mono text-blue-500 shrink-0 mt-0.5 w-10">{cert.year}</span>
              <div>
                <p class="text-sm font-medium text-gray-800">{(cert as any)[lang]?.name ?? cert.name}</p>
                <p class="text-xs text-gray-400">{cert.issuer}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>

    <div class="mt-12">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">{ed.referencesLabel}</p>
      <div class="grid md:grid-cols-2 gap-4">
        {data.references.map(ref => {
          const local = ref[lang]
          return (
            <div class="bg-white rounded-xl border border-gray-200 p-5">
              <p class="text-sm font-medium text-gray-800">{ref.name}</p>
              <p class="text-xs text-gray-500 mt-0.5">{local.title}</p>
              <p class="text-xs text-gray-400">{local.org}</p>
            </div>
          )
        })}
      </div>
      <p class="text-xs text-gray-400 italic mt-4">{ed.availableOnRequest}</p>
    </div>
  </div>
</section>
