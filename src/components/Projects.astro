---
import projects from '../data/projects.json'

const featured = projects.find(p => p.featured)
const others = projects.filter(p => !p.featured)
---

<section id="projects" class="py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">What I've built</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">Projects</h2>

    {featured && (
      <div class="bg-white rounded-2xl border border-gray-200 p-8 mb-6 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-1 gap-2">
          <div class="flex items-center gap-3 flex-wrap">
            <h3 class="text-xl font-bold text-gray-900">{featured.title}</h3>
            {featured.subtitle && (
              <span class="text-sm text-gray-400">— {featured.subtitle}</span>
            )}
            <span class="text-xs font-semibold bg-blue-50 text-blue-600 px-2.5 py-0.5 rounded-full">
              Featured
            </span>
          </div>
          <span class="text-sm text-gray-400 shrink-0">{featured.period}</span>
        </div>
        <p class="text-sm font-medium text-blue-600 mb-4">{featured.role}</p>
        <p class="text-gray-600 mb-8">{featured.description}</p>

        {featured.phases && (
          <div class="space-y-7">
            {featured.phases.map(phase => (
              <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">
                  {phase.year}
                </p>
                <ul class="space-y-1 mb-3">
                  {phase.highlights.map(h => (
                    <li class="flex gap-2 text-sm text-gray-500">
                      <span class="text-gray-300 shrink-0">—</span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5">
                  {phase.tech.map(t => (
                    <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">{t}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <div class="grid md:grid-cols-2 gap-4">
      {others.map(project => (
        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:border-blue-200 hover:shadow-md transition-all duration-200">
          <div class="flex items-start justify-between mb-1 gap-2">
            <div>
              <h3 class="font-semibold text-gray-900">{project.title}</h3>
              {project.subtitle && (
                <p class="text-xs text-gray-400">{project.subtitle}</p>
              )}
            </div>
            <span class="text-xs text-gray-400 shrink-0 whitespace-nowrap">{project.period}</span>
          </div>
          <p class="text-xs font-medium text-blue-600 mb-3">{project.role}</p>
          <p class="text-sm text-gray-500 mb-4">{project.description}</p>
          <div class="flex flex-wrap gap-1.5">
            {project.tech.map(t => (
              <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
