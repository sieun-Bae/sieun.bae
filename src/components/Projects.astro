---
import { useTranslations, type Lang } from '../i18n/translations'
import projects from '../data/projects.json'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)
const s = t.sections.projects

type Section = { title: string; bullets: string[]; divider?: boolean }
type LocalData = { subtitle?: string; role: string; description: string; tech?: string[]; phases?: { year: number; highlights: string[]; tech: string[] }[]; sections?: Section[] }

const featured = projects.find(p => p.featured)
const others = projects.filter(p => !p.featured)
const detailProjects = projects.filter(p => !!(p[lang] as LocalData).sections?.length)
---

<section id="projects" class="py-24 bg-gray-50">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">{s.eyebrow}</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">{s.heading}</h2>

    {featured && (() => {
      const local = featured[lang] as LocalData
      const allTech = [...new Set((local.phases ?? []).flatMap(p => p.tech))]
      return (
        <button
          type="button"
          data-open-modal={featured.id}
          class="w-full text-left bg-white rounded-2xl border border-gray-200 p-8 mb-6 shadow-sm hover:border-blue-200 hover:shadow-md transition-all duration-200 cursor-pointer group"
        >
          <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-1 gap-2">
            <div class="flex items-center gap-3 flex-wrap">
              <h3 class="text-xl font-bold text-gray-900">{featured.title}</h3>
              {local.subtitle && <span class="text-sm text-gray-400">— {local.subtitle}</span>}
              <span class="text-xs font-semibold bg-blue-50 text-blue-600 px-2.5 py-0.5 rounded-full">
                {t.projects.featuredLabel}
              </span>
            </div>
            <span class="text-sm text-gray-400 shrink-0">{featured.period}</span>
          </div>
          <p class="text-sm font-medium text-blue-600 mb-4">{local.role}</p>
          <p class="text-gray-600 mb-6">{local.description}</p>
          <div class="flex flex-wrap gap-1.5 mb-6">
            {allTech.map((tech: string) => (
              <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">{tech}</span>
            ))}
          </div>
          <div class="flex items-center gap-1.5 text-xs font-semibold text-blue-600 transition-all duration-200 group-hover:gap-2.5">
            <span>{t.projects.viewTimeline}</span>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </button>
      )
    })()}

    <div class="grid md:grid-cols-2 gap-4">
      {others.map(project => {
        const local = project[lang] as LocalData
        const hasDetail = !!local.sections?.length
        return (
          <div
            {...(hasDetail ? { 'data-open-modal': project.id } : {})}
            class:list={['bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:border-blue-200 hover:shadow-md transition-all duration-200', hasDetail && 'cursor-pointer group']}
          >
            <div class="flex items-start justify-between mb-1 gap-2">
              <div>
                <h3 class="font-semibold text-gray-900">{project.title}</h3>
                {local.subtitle && <p class="text-xs text-gray-400">{local.subtitle}</p>}
              </div>
              <span class="text-xs text-gray-400 shrink-0 whitespace-nowrap">{project.period}</span>
            </div>
            <p class="text-xs font-medium text-blue-600 mb-3">{local.role}</p>
            <p class="text-sm text-gray-500 mb-4">{local.description}</p>
            <div class="flex flex-wrap gap-1.5" class:list={[hasDetail && 'mb-4']}>
              {(local.tech ?? []).map((tech: string) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">{tech}</span>
              ))}
            </div>
            {hasDetail && (
              <div class="flex items-center gap-1.5 text-xs font-semibold text-blue-600 transition-all duration-200 group-hover:gap-2.5">
                <span>{t.projects.viewTimeline}</span>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            )}
          </div>
        )
      })}
    </div>
  </div>
</section>

{detailProjects.map(project => {
  const local = project[lang] as LocalData
  return (
    <div id={`modal-${project.id}`} class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
      <div
        id={`backdrop-${project.id}`}
        data-close-modal={project.id}
        class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"
      ></div>
      <div class="absolute inset-0 flex items-center justify-center p-6 pointer-events-none">
        <div
          id={`panel-${project.id}`}
          class="pointer-events-auto relative w-full max-w-3xl max-h-[85vh] bg-white rounded-2xl shadow-2xl overflow-y-auto opacity-0 scale-95 transition-all duration-300 ease-out"
        >
          <div class="sticky top-0 bg-white/95 backdrop-blur-sm border-b border-gray-100 px-8 py-4 flex items-center justify-between z-10">
            <div class="flex items-center gap-3">
              <span class="font-bold text-gray-900 text-lg">{project.title}</span>
              {local.subtitle && <span class="text-xs text-gray-400 hidden sm:block">— {local.subtitle}</span>}
            </div>
            <button
              data-close-modal={project.id}
              aria-label="Close"
              class="p-2 rounded-full hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <div class="px-8 py-8">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-sm font-semibold text-blue-600">{local.role}</span>
              <span class="text-gray-300">·</span>
              <span class="text-sm text-gray-400">{project.period}</span>
            </div>
            <p class="text-gray-600 mb-10 leading-relaxed">{local.description}</p>

            <div class="space-y-8">
              {(local.sections ?? []).map((section: Section) => (
                <div class:list={[section.divider && 'border-t border-gray-100 pt-8']}>
                  <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-3">{section.title}</p>
                  <ul class="space-y-2.5">
                    {section.bullets.map((b: string) => (
                      <li class="flex gap-2.5 text-sm text-gray-600">
                        <span class="text-gray-300 shrink-0 mt-0.5">—</span>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  )
})}

<script>
  function openProjectModal(id: string) {
    const modal    = document.getElementById(`modal-${id}`)
    const panel    = document.getElementById(`panel-${id}`)
    const backdrop = document.getElementById(`backdrop-${id}`)
    if (!modal) return
    modal.classList.remove('hidden')
    requestAnimationFrame(() => {
      backdrop?.classList.remove('opacity-0')
      panel?.classList.remove('opacity-0', 'scale-95')
    })
    document.body.style.overflow = 'hidden'
  }

  function closeProjectModal(id: string) {
    const modal    = document.getElementById(`modal-${id}`)
    const panel    = document.getElementById(`panel-${id}`)
    const backdrop = document.getElementById(`backdrop-${id}`)
    panel?.classList.add('opacity-0', 'scale-95')
    backdrop?.classList.add('opacity-0')
    setTimeout(() => modal?.classList.add('hidden'), 300)
    document.body.style.overflow = ''
  }

  document.querySelectorAll<HTMLElement>('[data-open-modal]').forEach(el => {
    el.addEventListener('click', () => { if (el.dataset.openModal) openProjectModal(el.dataset.openModal) })
  })

  document.querySelectorAll<HTMLElement>('[data-close-modal]').forEach(el => {
    el.addEventListener('click', () => { if (el.dataset.closeModal) closeProjectModal(el.dataset.closeModal) })
  })

  document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return
    document.querySelectorAll('[id^="modal-"]:not(.hidden)').forEach(modal => {
      closeProjectModal(modal.id.slice(6))
    })
  })
</script>
