---
import { useTranslations, type Lang } from '../i18n/translations'
import skills from '../data/skills.json'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)
const s = t.sections.skills
---

<section id="skills" class="py-24 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">{s.eyebrow}</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">{s.heading}</h2>

    <div class="mb-10">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">
        {t.skills.languagesLabel}
      </p>
      <div class="flex flex-wrap gap-4">
        {skills.languages.map(lang_ => (
          <div class="flex items-center gap-2">
            <span class="font-medium text-gray-800 text-sm">{lang_.name}</span>
            <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
              {lang_[lang]}
            </span>
          </div>
        ))}
      </div>
    </div>

    <div class="space-y-5">
      {skills.categories.map(category => (
        <div class="flex flex-col md:flex-row md:items-start gap-3 md:gap-6">
          <p class="text-sm font-semibold text-gray-600 w-32 shrink-0 pt-1">{category[lang]}</p>
          <div class="flex flex-wrap gap-2">
            {category.items.map(item => (
              <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full hover:bg-blue-50 hover:text-blue-700 transition-colors cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
