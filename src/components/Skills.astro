---
import skills from '../data/skills.json'
---

<section id="skills" class="py-24 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">Technical abilities</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">Skills</h2>

    <div class="mb-10">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Languages</p>
      <div class="flex flex-wrap gap-4">
        {skills.languages.map(lang => (
          <div class="flex items-center gap-2">
            <span class="font-medium text-gray-800 text-sm">{lang.name}</span>
            <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{lang.level}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="space-y-5">
      {skills.categories.map(category => (
        <div class="flex flex-col md:flex-row md:items-start gap-3 md:gap-6">
          <p class="text-sm font-semibold text-gray-600 w-28 shrink-0 pt-1">{category.label}</p>
          <div class="flex flex-wrap gap-2">
            {category.items.map(item => (
              <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full hover:bg-blue-50 hover:text-blue-700 transition-colors cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
