---
import { useTranslations, type Lang } from '../i18n/translations'
import experience from '../data/experience.json'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)
const s = t.sections.experience
---

<section id="experience" class="py-24 border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold text-blue-600 uppercase tracking-widest mb-2">{s.eyebrow}</p>
    <h2 class="text-3xl font-bold text-gray-900 mb-12">{s.heading}</h2>

    <div class="space-y-10">
      {experience.map(job => {
        const local = job[lang]
        return (
          <div class="relative pl-6 border-l-2 border-gray-200 hover:border-blue-400 transition-colors duration-200">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-2 gap-1">
              <div>
                <h3 class="font-semibold text-gray-900">{job.company}</h3>
                <p class="text-sm font-medium text-blue-600">{local.role}</p>
                <p class="text-xs text-gray-400">{job.location}</p>
              </div>
              <span class="text-sm text-gray-400 shrink-0">{job.period}</span>
            </div>
            <ul class="mt-3 space-y-1.5">
              {local.highlights.map((h: string) => (
                <li class="flex gap-2 text-sm text-gray-500">
                  <span class="text-gray-300 mt-0.5 shrink-0">—</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      })}
    </div>
  </div>
</section>
